<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:background="@drawable/bg_item_selector"
    android:padding="14dp" android:gravity="center_vertical">
    <TextView android:id="@+id/tvPlaylistIndex" android:layout_width="32dp"
        android:layout_height="wrap_content" android:textColor="@color/reva_accent"
        android:textSize="14sp" android:textStyle="bold" android:gravity="center" />
    <TextView android:id="@+id/tvPlaylistTitle" android:layout_width="0dp"
        android:layout_height="wrap_content" android:layout_weight="1"
        android:textColor="@color/reva_text_primary" android:textSize="14sp"
        android:ellipsize="end" android:lines="1" android:paddingStart="8dp" />
</LinearLayout>
