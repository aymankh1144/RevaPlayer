<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:background="@drawable/bg_item_selector"
    android:padding="14dp" android:gravity="center_vertical" android:layout_marginBottom="1dp">

    <TextView android:id="@+id/tvFileIcon" android:layout_width="36dp"
        android:layout_height="36dp" android:gravity="center"
        android:textSize="20sp" android:layout_marginEnd="12dp" />

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tvFileName" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textColor="@color/reva_text_primary"
            android:textSize="14sp" android:ellipsize="end" android:lines="1" />
        <TextView android:id="@+id/tvFileMeta" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textColor="@color/reva_text_secondary"
            android:textSize="11sp" android:paddingTop="2dp" />
    </LinearLayout>

    <TextView android:id="@+id/btnPlayFolder" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:text="▶ كل الملفات"
        android:textColor="@color/reva_accent" android:textSize="12sp"
        android:background="@drawable/bg_badge" android:paddingHorizontal="8dp"
        android:paddingVertical="4dp" android:visibility="gone" />
</LinearLayout>
