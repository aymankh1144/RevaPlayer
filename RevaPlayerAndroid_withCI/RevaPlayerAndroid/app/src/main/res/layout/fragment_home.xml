<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/reva_bg" android:fillViewport="true">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <!-- Header -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingBottom="16dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Reva Player" android:textColor="@color/reva_text_primary"
                    android:textSize="22sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="مشغل الفيديو المحلي" android:textColor="@color/reva_text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Search Button -->
            <android.widget.ImageButton android:id="@+id/btnSearch"
                android:layout_width="40dp" android:layout_height="40dp"
                android:background="@drawable/bg_icon_button"
                android:src="@drawable/ic_search" android:tint="@color/reva_text_primary"
                android:layout_marginEnd="8dp" />
        </LinearLayout>

        <!-- Quick Actions -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="20dp">

            <LinearLayout android:id="@+id/btnBrowseFolders"
                android:layout_width="0dp" android:layout_height="64dp"
                android:layout_weight="1" android:orientation="horizontal"
                android:background="@drawable/bg_card" android:gravity="center_vertical"
                android:padding="14dp" android:clickable="true" android:focusable="true"
                android:layout_marginEnd="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📁  " android:textSize="18sp" />
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="تصفح الملفات" android:textColor="@color/reva_text_primary"
                        android:textSize="13sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="المجلدات المحلية" android:textColor="@color/reva_text_secondary"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:id="@+id/btnOpenFile2"
                android:layout_width="0dp" android:layout_height="64dp"
                android:layout_weight="1" android:orientation="horizontal"
                android:background="@drawable/bg_resume_card" android:gravity="center_vertical"
                android:padding="14dp" android:clickable="true" android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🎬  " android:textSize="18sp" />
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="فتح ملف" android:textColor="@color/reva_text_primary"
                        android:textSize="13sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="اختر من الجهاز" android:textColor="@color/reva_text_secondary"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Resume Card -->
        <LinearLayout android:id="@+id/resumeCard"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/bg_resume_card"
            android:padding="16dp" android:layout_marginBottom="20dp"
            android:clickable="true" android:focusable="true"
            android:visibility="gone">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="▶  متابعة المشاهدة" android:textColor="@color/reva_accent"
                android:textSize="11sp" android:textStyle="bold" android:paddingBottom="8dp" />

            <TextView android:id="@+id/resumeTitle" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:textColor="@color/reva_text_primary"
                android:textSize="15sp" android:textStyle="bold"
                android:ellipsize="end" android:lines="1" android:paddingBottom="8dp" />

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingBottom="10dp">
                <TextView android:id="@+id/resumeProgress" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:textColor="@color/reva_text_secondary" android:textSize="12sp"
                    android:fontFamily="monospace" />
                <TextView android:id="@+id/resumePercent" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="@color/reva_accent"
                    android:textSize="13sp" android:textStyle="bold" />
            </LinearLayout>

            <ProgressBar android:id="@+id/resumeProgressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent" android:layout_height="4dp"
                android:progressTint="@color/reva_accent"
                android:progressBackgroundTint="@color/reva_seekbar_track" />
        </LinearLayout>

        <!-- Recent Header -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingBottom="10dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="الأخيرة"
                android:textColor="@color/reva_text_secondary" android:textSize="12sp"
                android:textStyle="bold" android:letterSpacing="0.08" />
        </LinearLayout>

        <!-- Empty State -->
        <LinearLayout android:id="@+id/emptyState" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="vertical"
            android:gravity="center" android:paddingVertical="40dp" android:visibility="visible">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📂" android:textSize="44sp" android:paddingBottom="12dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="لا يوجد محتوى بعد"
                android:textColor="@color/reva_text_primary" android:textSize="15sp"
                android:textStyle="bold" android:paddingBottom="6dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="اضغط + لفتح فيديو أو تصفح المجلدات"
                android:textColor="@color/reva_text_secondary" android:textSize="13sp"
                android:gravity="center" />
        </LinearLayout>

        <!-- Recent List -->
        <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvRecent"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false" android:visibility="gone" />

    </LinearLayout>
</ScrollView>
