<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:background="@color/reva_bg_surface">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="قائمة التشغيل" android:textColor="@color/reva_text_primary"
        android:textSize="16sp" android:textStyle="bold" android:padding="16dp" />
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/reva_border" />
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvPlaylist"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:maxHeight="400dp" android:padding="8dp" />
</LinearLayout>
